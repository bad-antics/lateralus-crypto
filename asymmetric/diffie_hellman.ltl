// crypto/asymmetric/diffie_hellman.ltl — DH key agreement (RFC 2631, RFC 3526).
//
// Diffie–Hellman (1976), the first public-key algorithm. Each party
// picks a secret x, publishes g^x mod p. Shared secret is g^(xy) mod p.
// Security rests on the Computational Diffie–Hellman (CDH) assumption.
//
// MODP primes (RFC 3526) are "safe primes": p = 2q+1 with q also prime.
// Use Group 14 (2048 bits) minimum; 3072+ preferred. For new systems
// prefer Curve25519 (X25519) or Curve448 — smaller keys, constant-time
// scalar multiplication, immune to small-subgroup attacks.
//
// Must validate peer public key: 1 < Y < p-1 AND Y^q ≡ 1 (mod p), else
// attacker can force the shared secret into a small subgroup.

module crypto.asymmetric.diffie_hellman

use crypto.asymmetric.rsa_simple   // reuse mod_pow

/// RFC 3526 Group 14 (2048-bit MODP, g = 2). Truncated literal shown;
/// real implementations embed the full prime.
pub const MODP_2048_G: int = 2
pub const MODP_2048_P: int = 

pub struct KeyPair { pub public: int, pub private: int }

pub fn generate_keypair(p: int, g: int, private_key: int) -> KeyPair {
    if private_key < 2 || private_key >= p - 1 {
        throw Error("DH: private key out of range")
    }
    return KeyPair { private: private_key, public: rsa_simple.mod_pow(g, private_key, p) }
}

pub fn compute_shared(p: int, peer_public: int, my_private: int) -> int {
    // REQUIRED peer validation: 1 < Y < p-1
    if peer_public <= 1 || peer_public >= p - 1 {
        throw Error("DH: invalid peer public key (possible small-subgroup attack)")
    }
    return rsa_simple.mod_pow(peer_public, my_private, p)
}

/// Tiny-DH demo (p = 23, g = 5). DO NOT USE for real security.
pub fn demo() -> bool {
    let p = 23; let g = 5
    let alice = generate_keypair(p, g, 6)
    let bob   = generate_keypair(p, g, 15)
    let alice_shared = compute_shared(p, bob.public, alice.private)
    let bob_shared   = compute_shared(p, alice.public, bob.private)
    return alice_shared == bob_shared
}
