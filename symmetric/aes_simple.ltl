const RCON: list = [0x01,0x02,0x04,0x08,0x10,0x20,0x40,0x80,0x1b,0x36]

// GF(2⁸) multiply by x (xtime): shift left, XOR with 0x1B on overflow.
fn xtime(b: int) -> int {
    let shifted = (b << 1) & 0xFF
    if (b & 0x80) != 0 { return shifted ^ 0x1B }
    return shifted
}

fn gmul(a: int, b: int) -> int {
    let mut p = 0
    let mut aa = a; let mut bb = b
    let mut i = 0
    while i < 8 {
        if (bb & 1) != 0 { p = p ^ aa }
        aa = xtime(aa)
        bb = bb >> 1
        i += 1
    }
    return p & 0xFF
}

pub fn key_expansion(key: list) -> list {
    if len(key) != 16 { throw Error("AES-128 needs a 16-byte key") }
    let mut w = key
    let mut i = 16
    while i < 176 {  // 11 round keys × 16 bytes
        let mut temp = [w[i-4], w[i-3], w[i-2], w[i-1]]
        if (i % 16) == 0 {
            // RotWord + SubWord + Rcon
            let t0 = SBOX[temp[1]] ^ RCON[(i / 16) - 1]
            let t1 = SBOX[temp[2]]
            let t2 = SBOX[temp[3]]
            let t3 = SBOX[temp[0]]
            temp = [t0, t1, t2, t3]
        }
        let mut j = 0
        while j < 4 { w = push(w, w[i - 16 + j] ^ temp[j]); j += 1 }
        i += 4
    }
    return w
}

pub fn encrypt_block(key: list, block: list) -> list {
    if len(block) != 16 { throw Error("AES block is 16 bytes") }
    let rk = key_expansion(key)
    let mut state = block
    state = add_round_key(state, rk, 0)
    let mut r = 1
    while r < 10 {
        state = sub_bytes(state, false)
        state = shift_rows(state, false)
        state = mix_columns(state, false)
        state = add_round_key(state, rk, r)
        r += 1
    }
    state = sub_bytes(state, false)
    state = shift_rows(state, false)
    state = add_round_key(state, rk, 10)
    return state
}

pub fn decrypt_block(key: list, block: list) -> list {
    let rk = key_expansion(key)
    let mut state = block
    state = add_round_key(state, rk, 10)
    state = shift_rows(state, true)
    state = sub_bytes(state, true)
    let mut r = 9
    while r >= 1 {
        state = add_round_key(state, rk, r)
        state = mix_columns(state, true)
        state = shift_rows(state, true)
        state = sub_bytes(state, true)
        r -= 1
    }
    state = add_round_key(state, rk, 0)
    return state
}

fn add_round_key(state: list, rk: list, round: int) -> list {
    let mut out = []
    let mut i = 0
    while i < 16 { out = push(out, state[i] ^ rk[round * 16 + i]); i += 1 }
    return out
}

fn sub_bytes(state: list, inverse: bool) -> list {
    let mut out = []
    for b in state {
        out = push(out, if inverse { INV_SBOX[b] } else { SBOX[b] })
    }
    return out
}

fn shift_rows(state: list, inverse: bool) -> list {
    // Column-major state: state[r + 4*c].
    let mut out = []
    let mut i = 0
    while i < 16 { out = push(out, 0); i += 1 }
    let mut r = 0
    while r < 4 {
        let mut c = 0
        while c < 4 {
            let src_c = if inverse { (c - r + 4) % 4 } else { (c + r) % 4 }
            out[r + 4 * c] = state[r + 4 * src_c]
            c += 1
        }
        r += 1
    }
    return out
}

fn mix_columns(state: list, inverse: bool) -> list {
    let mut out = []
    let mut i = 0
    while i < 16 { out = push(out, 0); i += 1 }
    let mut c = 0
    while c < 4 {
        let base = 4 * c
        let s0 = state[base]; let s1 = state[base+1]
        let s2 = state[base+2]; let s3 = state[base+3]
        if inverse {
            out[base]   = gmul(0x0e, s0) ^ gmul(0x0b, s1) ^ gmul(0x0d, s2) ^ gmul(0x09, s3)
            out[base+1] = gmul(0x09, s0) ^ gmul(0x0e, s1) ^ gmul(0x0b, s2) ^ gmul(0x0d, s3)
            out[base+2] = gmul(0x0d, s0) ^ gmul(0x09, s1) ^ gmul(0x0e, s2) ^ gmul(0x0b, s3)
            out[base+3] = gmul(0x0b, s0) ^ gmul(0x0d, s1) ^ gmul(0x09, s2) ^ gmul(0x0e, s3)
        } else {
            out[base]   = gmul(2, s0) ^ gmul(3, s1) ^ s2 ^ s3
            out[base+1] = s0 ^ gmul(2, s1) ^ gmul(3, s2) ^ s3
            out[base+2] = s0 ^ s1 ^ gmul(2, s2) ^ gmul(3, s3)
            out[base+3] = gmul(3, s0) ^ s1 ^ s2 ^ gmul(2, s3)
        }
        c += 1
    }
    return out
}

pub fn to_hex(bytes: list) -> str {
    let chars = "0123456789abcdef"
    let mut out = ""
    for byte in bytes { out += chars[byte / 16] as str + chars[byte % 16] as str }
    return out
}

fn main() {
    let key = [0x00,0x01,0x02,0x03,0x04,0x05,0x06,0x07,
               0x08,0x09,0x0a,0x0b,0x0c,0x0d,0x0e,0x0f]
    let pt  = [0x00,0x11,0x22,0x33,0x44,0x55,0x66,0x77,
               0x88,0x99,0xaa,0xbb,0xcc,0xdd,0xee,0xff]
    println("ct       = " + to_hex(encrypt_block(key, pt)))
    println("expected = 69c4e0d86a7b0430d8cdb78070b4c55a")
}
