// crypto/symmetric/aes_simple.ltl — FIPS 197 AES-128 block cipher.
//
// Implements the full AES-128 block cipher (16-byte block, 10 rounds,
// 128-bit key). SubBytes uses the standard S-box; ShiftRows and
// MixColumns use the GF(2⁸) polynomial x⁸ + x⁴ + x³ + x + 1 = 0x11B.
// This module exports only the raw block permutation — use
// `modes/cbc_mode`, `modes/ctr_mode`, or `modes/gcm_mode` for a full
// cipher. Never call this directly for encrypting more than 16 bytes
// without a mode.
//
// Test vector (FIPS 197 Appendix B):
//   key = 000102030405060708090a0b0c0d0e0f
//   pt  = 00112233445566778899aabbccddeeff
//   ct  = 69c4e0d86a7b0430d8cdb78070b4c55a

module crypto.symmetric.aes_simple

